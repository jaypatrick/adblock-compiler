// Prisma Schema for AdBlock Compiler
//
// PostgreSQL via PlanetScale or Neon, accessed through Cloudflare Hyperdrive.
// Local development uses a local PostgreSQL instance (Docker or native).
//
// Usage:
//   Local:      DATABASE_URL="postgresql://<user>:<password>@127.0.0.1:5432/<db_name>"  # See .env.example or docs/database-setup/local-dev.md
//   Production: Set via `wrangler secret put DATABASE_URL` (PlanetScale/Neon connection string)
//
// Migrations:
//   npx prisma migrate dev --name <description>   # Create + apply migration locally
//   npx prisma migrate deploy                      # Apply pending migrations (CI/prod)

generator client {
  provider = "prisma-client"
  output   = "./generated"
  // Use edge-compatible runtime for Cloudflare Workers
  // For local dev with Deno, set runtime = "deno"
}

datasource db {
  provider = "postgresql"
  // Connection URL is configured in prisma.config.ts (Prisma 7+)
}

// ============================================================================
// Authentication
// ============================================================================

model User {
  id             String    @id @default(uuid()) @db.Uuid
  email          String?   @unique
  displayName    String?   @map("display_name")
  role           String    @default("user") // admin | user | readonly
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Clerk integration fields
  clerkUserId    String?   @unique @map("clerk_user_id")
  tier           String    @default("free") // anonymous | free | pro | admin
  firstName      String?   @map("first_name")
  lastName       String?   @map("last_name")
  imageUrl       String?   @map("image_url")
  emailVerified  Boolean   @default(false) @map("email_verified")
  lastSignInAt   DateTime? @map("last_sign_in_at") @db.Timestamptz

  // Better Auth: two-factor authentication status
  twoFactorEnabled Boolean @default(false) @map("two_factor_enabled")

  apiKeys       ApiKey[]
  sessions      Session[]
  accounts      Account[]
  twoFactor     TwoFactor?
  agentSessions AgentSession[]

  @@map("users")
}

model ApiKey {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  keyHash            String    @unique @map("key_hash")
  keyPrefix          String    @map("key_prefix") // first 8 chars for display
  name               String
  scopes             String[]  @default(["compile"])
  rateLimitPerMinute Int       @default(60) @map("rate_limit_per_minute")
  lastUsedAt         DateTime? @map("last_used_at") @db.Timestamptz
  expiresAt          DateTime? @map("expires_at") @db.Timestamptz
  revokedAt          DateTime? @map("revoked_at") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique                       // Better Auth session token
  tokenHash String?  @unique @map("token_hash")     // Legacy (Clerk); nullable for Better Auth sessions
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

/// Better Auth twoFactor plugin — stores TOTP secrets and backup codes per user.
model TwoFactor {
  id          String @id @default(uuid()) @db.Uuid
  userId      String @map("user_id") @db.Uuid
  secret      String // encrypted TOTP secret
  backupCodes String @map("backup_codes") // JSON-encoded backup code array

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("two_factor")
}

model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz
  scope                 String?
  idToken               String?   @map("id_token")
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId], map: "account_user_provider_unique")
  @@index([userId], map: "account_user_id_idx")
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("verification")
}

// ============================================================================
// Filter Sources & Versions
// ============================================================================

model FilterSource {
  id                     String    @id @default(uuid()) @db.Uuid
  url                    String    @unique
  name                   String
  description            String?
  homepage               String?
  license                String?
  isPublic               Boolean   @default(true) @map("is_public")
  ownerUserId            String?   @map("owner_user_id") @db.Uuid
  refreshIntervalSeconds Int       @default(3600) @map("refresh_interval_seconds")
  lastCheckedAt          DateTime? @map("last_checked_at") @db.Timestamptz
  lastSuccessAt          DateTime? @map("last_success_at") @db.Timestamptz
  lastFailureAt          DateTime? @map("last_failure_at") @db.Timestamptz
  consecutiveFailures    Int       @default(0) @map("consecutive_failures")
  status                 String    @default("unknown") // healthy | degraded | unhealthy | unknown
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  versions       FilterListVersion[]
  healthSnapshots SourceHealthSnapshot[]
  changeEvents   SourceChangeEvent[]

  @@index([status])
  @@map("filter_sources")
}

model FilterListVersion {
  id          String    @id @default(uuid()) @db.Uuid
  sourceId    String    @map("source_id") @db.Uuid
  contentHash String    @map("content_hash")
  ruleCount   Int       @map("rule_count")
  etag        String?
  r2Key       String    @map("r2_key") // pointer to R2 object
  fetchedAt   DateTime  @default(now()) @map("fetched_at") @db.Timestamptz
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz
  isCurrent   Boolean   @default(false) @map("is_current")

  source FilterSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  // Note: We intentionally avoid a unique constraint on (sourceId, isCurrent) because
  // that would prevent storing multiple historical (non-current) versions per source.
  // To enforce "at most one current version per source" at the database level, apply a
  // PostgreSQL partial unique index via a SQL migration (sourceId maps to source_id column):
  //   CREATE UNIQUE INDEX idx_filter_list_versions_current ON filter_list_versions(source_id) WHERE is_current = true;
  @@index([sourceId, isCurrent], name: "idx_filter_list_versions_source_current")
  @@index([contentHash])
  @@map("filter_list_versions")
}

// ============================================================================
// Compiled Outputs
// ============================================================================

model CompiledOutput {
  id             String    @id @default(uuid()) @db.Uuid
  configHash     String    @unique @map("config_hash")
  configName     String    @map("config_name")
  configSnapshot Json      @map("config_snapshot") @db.JsonB
  ruleCount      Int       @map("rule_count")
  sourceCount    Int       @map("source_count")
  durationMs     Int       @map("duration_ms")
  r2Key          String    @map("r2_key")
  ownerUserId    String?   @map("owner_user_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz

  events CompilationEvent[]

  @@index([configName])
  @@index([createdAt(sort: Desc)])
  @@index([ownerUserId])
  @@map("compiled_outputs")
}

// ============================================================================
// Compilation Events (append-only telemetry)
// ============================================================================

model CompilationEvent {
  id               String    @id @default(uuid()) @db.Uuid
  compiledOutputId String?   @map("compiled_output_id") @db.Uuid
  userId           String?   @map("user_id") @db.Uuid
  apiKeyId         String?   @map("api_key_id") @db.Uuid
  requestSource    String    @map("request_source") // worker | cli | batch_api | workflow
  workerRegion     String?   @map("worker_region")
  durationMs       Int       @map("duration_ms")
  cacheHit         Boolean   @default(false) @map("cache_hit")
  errorMessage     String?   @map("error_message")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  compiledOutput CompiledOutput? @relation(fields: [compiledOutputId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@map("compilation_events")
}

// ============================================================================
// Source Health Tracking
// ============================================================================

model SourceHealthSnapshot {
  id                  String   @id @default(uuid()) @db.Uuid
  sourceId            String   @map("source_id") @db.Uuid
  status              String   // healthy | degraded | unhealthy
  totalAttempts       Int      @default(0) @map("total_attempts")
  successfulAttempts  Int      @default(0) @map("successful_attempts")
  failedAttempts      Int      @default(0) @map("failed_attempts")
  consecutiveFailures Int      @default(0) @map("consecutive_failures")
  avgDurationMs       Float    @default(0) @map("avg_duration_ms")
  avgRuleCount        Float    @default(0) @map("avg_rule_count")
  recordedAt          DateTime @default(now()) @map("recorded_at") @db.Timestamptz

  source FilterSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([recordedAt(sort: Desc)])
  @@map("source_health_snapshots")
}

model SourceChangeEvent {
  id                 String   @id @default(uuid()) @db.Uuid
  sourceId           String   @map("source_id") @db.Uuid
  previousVersionId  String?  @map("previous_version_id") @db.Uuid
  newVersionId       String   @map("new_version_id") @db.Uuid
  ruleCountDelta     Int      @default(0) @map("rule_count_delta")
  contentHashChanged Boolean  @default(true) @map("content_hash_changed")
  detectedAt         DateTime @default(now()) @map("detected_at") @db.Timestamptz

  source FilterSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([detectedAt(sort: Desc)])
  @@map("source_change_events")
}

// ============================================================================
// Agent Sessions — tracks active and historical Cloudflare Agents connections
// ============================================================================

model AgentSession {
  id           String    @id @default(uuid()) @db.Uuid
  agentSlug    String    @map("agent_slug") // from AGENT_REGISTRY slug
  instanceId   String    @map("instance_id") // Durable Object instance name
  userId       String?   @map("user_id") @db.Uuid
  clerkUserId  String?   @map("clerk_user_id")
  startedAt    DateTime  @default(now()) @map("started_at") @db.Timestamptz
  endedAt      DateTime? @map("ended_at") @db.Timestamptz // NULL = still active
  endReason    String?   @map("end_reason") // 'client_disconnect' | 'server_error' | 'admin_terminate' | 'timeout'
  messageCount Int       @default(0) @map("message_count") // incremented on each WS message
  transport    String    @default("websocket") // 'websocket' | 'sse'
  clientIp     String?   @map("client_ip")
  userAgent    String?   @map("user_agent")
  metadata     Json?     // JSON blob for future extensibility

  user        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  invocations AgentInvocation[]

  @@index([userId])
  @@index([clerkUserId])
  @@index([agentSlug])
  @@index([startedAt])
  @@index([userId, endedAt], name: "agent_sessions_user_active_idx") // "active sessions per user"
  @@map("agent_sessions")
}

/// Tracks individual tool calls / actions within a session.
model AgentInvocation {
  id            String       @id @default(uuid()) @db.Uuid
  sessionId     String       @map("session_id") @db.Uuid
  session       AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  toolName      String       @map("tool_name")
  inputSummary  String?      @map("input_summary")
  outputSummary String?      @map("output_summary")
  durationMs    Int?         @map("duration_ms")
  success       Boolean      @default(true)
  errorMessage  String?      @map("error_message")
  invokedAt     DateTime     @default(now()) @map("invoked_at") @db.Timestamptz
  metadata      Json?        @db.JsonB

  @@index([sessionId])
  @@index([toolName])
  @@index([invokedAt])
  @@map("agent_invocations")
}

/// Append-only audit log for all agent-related security events.
model AgentAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  agentSlug   String?  @map("agent_slug")
  instanceId  String?  @map("instance_id")
  action      String
  status      String   @default("success")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  reason      String?
  metadata    Json?    @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([actorUserId])
  @@index([agentSlug])
  @@index([action])
  @@index([createdAt])
  @@map("agent_audit_logs")
}

// ============================================================================
// Legacy: Generic Key-Value Storage (retained for backward compatibility)
// ============================================================================

model StorageEntry {
  id        String    @id @default(cuid())
  key       String    @unique
  data      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  expiresAt DateTime? @map("expires_at")
  tags      String?

  @@index([key])
  @@index([expiresAt])
  @@map("storage_entries")
}

model FilterCache {
  id        String    @id @default(cuid())
  source    String    @unique
  content   String
  hash      String
  etag      String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  expiresAt DateTime? @map("expires_at")

  @@index([source])
  @@index([expiresAt])
  @@map("filter_cache")
}

// ============================================================================
// Legacy: Compilation Metadata (retained for backward compatibility with PrismaStorageAdapter)
// ============================================================================
// TODO(Phase 2): Migrate callers to use CompiledOutput + CompilationEvent instead.

model CompilationMetadata {
  id          String   @id @default(cuid())
  configName  String
  timestamp   DateTime @default(now())
  sourceCount Int
  ruleCount   Int
  duration    Int      // Duration in milliseconds
  outputPath  String?

  @@index([configName])
  @@index([timestamp])
  @@map("compilation_metadata")
}
