// Prisma Schema for AdBlock Compiler
//
// PostgreSQL via Neon, accessed through Cloudflare Hyperdrive.
// Local development uses a Neon branch (see https://neon.com/guides/local-development-with-neon).
//
// Usage:
//   Local:      DIRECT_DATABASE_URL="<neon-branch-connection-string>"  # See .env.example or docs/database-setup/neon-cheatsheet.md
//   Production: Set via `wrangler secret put DATABASE_URL` (Neon main branch connection string)
//
// Migrations:
//   deno task db:migrate            # Create + apply migration locally
//   deno task db:migrate:deploy     # Apply pending migrations (CI/prod)

generator client {
  provider = "prisma-client"
  output   = "./generated"
  runtime  = "cloudflare"
  // "cloudflare" runtime uses @prisma/adapter-pg code path — no runtime WASM.
  // This is required for Cloudflare Workers which block WebAssembly.Module()
  // instantiation at runtime. The deno runtime would generate WASM-dependent
  // code that Cloudflare rejects.
  // See: https://www.prisma.io/docs/orm/prisma-client/deployment/edge/deploy-to-cloudflare
}

datasource db {
  provider = "postgresql"
  // Connection URL is configured in prisma.config.ts (Prisma 7+)
}

// ============================================================================
// Subscription Plans
// ============================================================================

/// Defines the capabilities and limits for each subscription tier.
/// Both users and organizations reference a plan — orgs can access
/// plans with higher limits (e.g. vendor, enterprise) not available to solo users.
/// Seed data: free, pro, vendor, enterprise plans should be inserted via a migration.
model SubscriptionPlan {
  id                   String   @id @default(uuid()) @db.Uuid
  name                 String   @unique  // "free" | "pro" | "vendor" | "enterprise"
  displayName          String   @map("display_name")
  isOrgOnly            Boolean  @default(false) @map("is_org_only") // vendor/enterprise plans only available to orgs
  maxApiKeysPerUser    Int      @default(3)    @map("max_api_keys_per_user")
  rateLimitPerMinute   Int      @default(60)   @map("rate_limit_per_minute")
  rateLimitPerDay      Int      @default(1000) @map("rate_limit_per_day")
  maxFilterSources     Int      @default(10)   @map("max_filter_sources")
  maxCompiledOutputs   Int      @default(50)   @map("max_compiled_outputs")
  maxOrgMembers        Int?     @map("max_org_members")          // NULL = unlimited
  astStorageEnabled    Boolean  @default(false) @map("ast_storage_enabled")
  translationEnabled   Boolean  @default(false) @map("translation_enabled")
  globalSharingEnabled Boolean  @default(false) @map("global_sharing_enabled")
  batchApiEnabled      Boolean  @default(false) @map("batch_api_enabled")
  retentionDays        Int      @default(90)  @map("retention_days")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @updatedAt     @map("updated_at") @db.Timestamptz

  users         User[]
  organizations Organization[]

  @@map("subscription_plans")
}

// ============================================================================
// Authentication
// ============================================================================

model User {
  id             String    @id @default(uuid()) @db.Uuid
  email          String?   @unique
  displayName    String?   @map("display_name")
  role           String    @default("user") // admin | user | readonly
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  tier           String    @default("free") // free | pro | vendor | enterprise (anonymous for unauthenticated hot-path; admin is a role, not a tier)
  firstName      String?   @map("first_name")
  lastName       String?   @map("last_name")
  imageUrl       String?   @map("image_url")
  emailVerified  Boolean   @default(false) @map("email_verified")
  lastSignInAt   DateTime? @map("last_sign_in_at") @db.Timestamptz

  // Better Auth: two-factor authentication status
  twoFactorEnabled Boolean @default(false) @map("two_factor_enabled")

  // Better Auth: ban management
  banned     Boolean   @default(false)
  banReason  String?   @map("ban_reason")
  banExpires DateTime? @map("ban_expires") @db.Timestamptz

  // Subscription plan — authoritative source for tier capabilities.
  // tier (String) is kept as a fast-read denormalized cache for the Worker hot path.
  // Keep tier in sync with plan.name whenever planId changes.
  planId       String?  @map("plan_id") @db.Uuid

  apiKeys       ApiKey[]
  sessions      Session[]
  accounts      Account[]
  twoFactor     TwoFactor?
  agentSessions AgentSession[]
  members       Member[]
  userConfigurations UserConfiguration[]
  plan                SubscriptionPlan?      @relation(fields: [planId], references: [id])
  filterSources       FilterSource[]
  configurations      Configuration[]
  filterListAsts      FilterListAst[]
  dataRetentionConsents DataRetentionConsent[]

  @@index([planId])
  @@map("users")
}

model ApiKey {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  keyHash            String    @unique @map("key_hash")
  keyPrefix          String    @map("key_prefix") // first 8 chars for display
  name               String
  scopes             String[]  @default(["compile"])
  rateLimitPerMinute Int       @default(60) @map("rate_limit_per_minute")
  lastUsedAt         DateTime? @map("last_used_at") @db.Timestamptz
  expiresAt          DateTime? @map("expires_at") @db.Timestamptz
  revokedAt          DateTime? @map("revoked_at") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, revokedAt])
  @@map("api_keys")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique                       // Better Auth session token
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

/// Better Auth twoFactor plugin — stores TOTP secrets and backup codes per user.
model TwoFactor {
  id          String @id @default(uuid()) @db.Uuid
  userId      String @map("user_id") @db.Uuid
  secret      String // encrypted TOTP secret
  backupCodes String @map("backup_codes") // JSON-encoded backup code array

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("two_factor")
}

model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz
  scope                 String?
  idToken               String?   @map("id_token")
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId], map: "account_user_provider_unique")
  @@index([userId], map: "account_user_id_idx")
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("verification")
}

/// Better Auth organization plugin — stores organizations for multi-tenancy.
model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  logo        String?
  metadata    Json?    @db.JsonB

  // Billing / subscription
  // tier is a denormalized cache — planId is authoritative.
  tier        String   @default("free")  // free | pro | vendor | enterprise
  planId      String?  @map("plan_id") @db.Uuid

  // Data retention policy — set from SubscriptionPlan.retentionDays on plan assignment.
  // Stored here for fast enforcement without a JOIN on every request.
  retentionDays             Int       @default(90)  @map("retention_days")
  retentionPolicyAcceptedAt DateTime? @map("retention_policy_accepted_at") @db.Timestamptz

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt      @map("updated_at") @db.Timestamptz

  plan                  SubscriptionPlan?      @relation(fields: [planId], references: [id])
  members               Member[]
  filterSources         FilterSource[]
  configurations        Configuration[]
  compiledOutputs       CompiledOutput[]
  filterListAsts        FilterListAst[]
  dataRetentionConsents DataRetentionConsent[]

  @@index([planId])
  @@map("organization")
}

/// Better Auth organization plugin — stores organization membership and roles.
model Member {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  role           String       // owner | admin | member
  // NULL = inherit org plan/tier. Set to override this member's effective tier
  // within the org (e.g. org is "vendor" but this member is limited to "pro" features).
  tierOverride   String?      @map("tier_override")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
  @@map("member")
}

// ============================================================================
// Filter Sources & Versions
// ============================================================================

/// A filter list source URL, scoped to either a user or an organization.
/// Global/public sources (e.g. EasyList, Hagezi) use visibility = "public" or "featured".
model FilterSource {
  id                     String    @id @default(uuid()) @db.Uuid
  url                    String
  name                   String
  description            String?
  homepage               String?
  license                String?

  // Ownership — one of these is set; both null for system-managed global sources.
  ownerUserId            String?   @map("owner_user_id") @db.Uuid
  organizationId         String?   @map("organization_id") @db.Uuid

  // Sharing / discovery
  // private  → only owner/org members can see and use this source
  // org      → all members of the owning org can see and use this source
  // public   → globally discoverable and usable by any authenticated user
  // featured → globally listed and pinned in UI (admin-set only)
  visibility             String    @default("private") @map("visibility")
  isFeatured             Boolean   @default(false) @map("is_featured")

  refreshIntervalSeconds Int       @default(3600) @map("refresh_interval_seconds")
  lastCheckedAt          DateTime? @map("last_checked_at") @db.Timestamptz
  lastSuccessAt          DateTime? @map("last_success_at") @db.Timestamptz
  lastFailureAt          DateTime? @map("last_failure_at") @db.Timestamptz
  consecutiveFailures    Int       @default(0) @map("consecutive_failures")
  status                 String    @default("unknown") // healthy | degraded | unhealthy | unknown
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  ownerUser       User?         @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions        FilterListVersion[]
  healthSnapshots SourceHealthSnapshot[]
  changeEvents    SourceChangeEvent[]
  filterListAsts  FilterListAst[]

  // A URL can appear multiple times in the table but must be unique per owner context.
  // Two different orgs can independently subscribe to the same upstream EasyList URL.
  @@unique([url, ownerUserId, organizationId], name: "filter_sources_url_owner_unique")
  @@index([ownerUserId])
  @@index([organizationId])
  @@index([visibility])
  @@index([status])
  @@map("filter_sources")
}

model FilterListVersion {
  id          String    @id @default(uuid()) @db.Uuid
  sourceId    String    @map("source_id") @db.Uuid
  contentHash String    @map("content_hash")
  ruleCount   Int       @map("rule_count")
  etag        String?
  r2Key       String    @map("r2_key") // pointer to R2 object
  fetchedAt   DateTime  @default(now()) @map("fetched_at") @db.Timestamptz
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz
  isCurrent   Boolean   @default(false) @map("is_current")

  source FilterSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  // Note: We intentionally avoid a unique constraint on (sourceId, isCurrent) because
  // that would prevent storing multiple historical (non-current) versions per source.
  // To enforce "at most one current version per source" at the database level, apply a
  // PostgreSQL partial unique index via a SQL migration (sourceId maps to source_id column):
  //   CREATE UNIQUE INDEX idx_filter_list_versions_current ON filter_list_versions(source_id) WHERE is_current = true;
  @@index([sourceId, isCurrent], name: "idx_filter_list_versions_source_current")
  @@index([contentHash])
  @@map("filter_list_versions")
}

// ============================================================================
// Filter List ASTs — parsed AST storage for power users and developers
// ============================================================================

/// Stores parsed AST representations of filter lists.
/// Gated by SubscriptionPlan.astStorageEnabled — only available to pro+ and vendor tiers.
/// The `ast` field is schema-agnostic JSON; the `parserVersion` field tracks which
/// parser version produced this AST so it can be re-parsed if the schema changes.
model FilterListAst {
  id             String   @id @default(uuid()) @db.Uuid
  ownerUserId    String?  @map("owner_user_id") @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  sourceId       String?  @map("source_id") @db.Uuid  // optional link to the FilterSource this was parsed from

  name           String
  ast            Json     @db.JsonB   // the parsed AST
  ruleCount      Int      @map("rule_count")
  parserVersion  String   @map("parser_version")  // semver — used to detect stale ASTs

  // private | org | public
  visibility     String   @default("private") @map("visibility")

  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt      @map("updated_at") @db.Timestamptz

  ownerUser      User?         @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  source         FilterSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@index([organizationId])
  @@index([sourceId])
  @@index([visibility])
  @@map("filter_list_asts")
}

// ============================================================================
// Compiled Outputs
// ============================================================================

model CompiledOutput {
  id             String    @id @default(uuid()) @db.Uuid
  configHash     String    @unique @map("config_hash")
  configName     String    @map("config_name")
  configSnapshot Json      @map("config_snapshot") @db.JsonB
  ruleCount      Int       @map("rule_count")
  sourceCount    Int       @map("source_count")
  durationMs     Int       @map("duration_ms")
  r2Key          String    @map("r2_key")
  ownerUserId    String?   @map("owner_user_id") @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  // private | org | public
  visibility     String    @default("private") @map("visibility")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz

  events       CompilationEvent[]
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([configName])
  @@index([createdAt(sort: Desc)])
  @@index([ownerUserId])
  @@index([organizationId])
  @@index([visibility])
  @@map("compiled_outputs")
}

// ============================================================================
// Configurations — personal, org-shared, and globally discoverable configs
// ============================================================================

/// Unified configuration model supporting personal, org-shared, and global sharing.
/// Replaces UserConfiguration (retained for backward compat — see legacy section).
/// Supports forking, starring, and ranking for publicly shared configurations.
model Configuration {
  id             String   @id @default(uuid()) @db.Uuid

  // Ownership — one of these is set
  ownerUserId    String?  @map("owner_user_id") @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid

  name           String
  description    String?
  config         Json     @db.JsonB

  // Sharing semantics
  // private → only the owner (user or org members via organizationId)
  // org     → all members of the owning org
  // public  → globally discoverable, rankable, forkable
  visibility     String   @default("private") @map("visibility")

  // Discovery / social features (only meaningful when visibility = "public")
  starCount      Int      @default(0) @map("star_count")
  forkCount      Int      @default(0) @map("fork_count")
  forkedFromId   String?  @map("forked_from_id") @db.Uuid

  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt      @map("updated_at") @db.Timestamptz

  ownerUser      User?          @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  forkedFrom     Configuration? @relation("ConfigForks", fields: [forkedFromId], references: [id], onDelete: SetNull)
  forks          Configuration[] @relation("ConfigForks")

  @@index([ownerUserId])
  @@index([organizationId])
  @@index([visibility])
  @@index([starCount(sort: Desc)])
  @@map("configurations")
}

// ============================================================================
// Compilation Events (append-only telemetry)
// ============================================================================

model CompilationEvent {
  id               String    @id @default(uuid()) @db.Uuid
  compiledOutputId String?   @map("compiled_output_id") @db.Uuid
  userId           String?   @map("user_id") @db.Uuid
  apiKeyId         String?   @map("api_key_id") @db.Uuid
  requestSource    String    @map("request_source") // worker | cli | batch_api | workflow
  workerRegion     String?   @map("worker_region")
  durationMs       Int       @map("duration_ms")
  cacheHit         Boolean   @default(false) @map("cache_hit")
  errorMessage     String?   @map("error_message")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  compiledOutput CompiledOutput? @relation(fields: [compiledOutputId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@map("compilation_events")
}

// ============================================================================
// Source Health Tracking
// ============================================================================

model SourceHealthSnapshot {
  id                  String   @id @default(uuid()) @db.Uuid
  sourceId            String   @map("source_id") @db.Uuid
  status              String   // healthy | degraded | unhealthy
  totalAttempts       Int      @default(0) @map("total_attempts")
  successfulAttempts  Int      @default(0) @map("successful_attempts")
  failedAttempts      Int      @default(0) @map("failed_attempts")
  consecutiveFailures Int      @default(0) @map("consecutive_failures")
  avgDurationMs       Float    @default(0) @map("avg_duration_ms")
  avgRuleCount        Float    @default(0) @map("avg_rule_count")
  recordedAt          DateTime @default(now()) @map("recorded_at") @db.Timestamptz

  source FilterSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([recordedAt(sort: Desc)])
  @@map("source_health_snapshots")
}

model SourceChangeEvent {
  id                 String   @id @default(uuid()) @db.Uuid
  sourceId           String   @map("source_id") @db.Uuid
  previousVersionId  String?  @map("previous_version_id") @db.Uuid
  newVersionId       String   @map("new_version_id") @db.Uuid
  ruleCountDelta     Int      @default(0) @map("rule_count_delta")
  contentHashChanged Boolean  @default(true) @map("content_hash_changed")
  detectedAt         DateTime @default(now()) @map("detected_at") @db.Timestamptz

  source FilterSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([detectedAt(sort: Desc)])
  @@map("source_change_events")
}

// ============================================================================
// Agent Sessions — tracks active and historical Cloudflare Agents connections
// ============================================================================

model AgentSession {
  id           String    @id @default(uuid()) @db.Uuid
  agentSlug    String    @map("agent_slug") // from AGENT_REGISTRY slug
  instanceId   String    @map("instance_id") // Durable Object instance name
  userId       String?   @map("user_id") @db.Uuid
  startedAt    DateTime  @default(now()) @map("started_at") @db.Timestamptz
  endedAt      DateTime? @map("ended_at") @db.Timestamptz // NULL = still active
  endReason    String?   @map("end_reason") // 'client_disconnect' | 'server_error' | 'admin_terminate' | 'timeout'
  messageCount Int       @default(0) @map("message_count") // incremented on each WS message
  transport    String    @default("websocket") // 'websocket' | 'sse'
  clientIp     String?   @map("client_ip")
  userAgent    String?   @map("user_agent")
  metadata     Json?     // JSON blob for future extensibility

  user        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  invocations AgentInvocation[]

  @@index([userId])
  @@index([agentSlug])
  @@index([startedAt])
  @@index([userId, endedAt], name: "agent_sessions_user_active_idx") // "active sessions per user"
  @@map("agent_sessions")
}

/// Tracks individual tool calls / actions within a session.
model AgentInvocation {
  id            String       @id @default(uuid()) @db.Uuid
  sessionId     String       @map("session_id") @db.Uuid
  session       AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  toolName      String       @map("tool_name")
  inputSummary  String?      @map("input_summary")
  outputSummary String?      @map("output_summary")
  durationMs    Int?         @map("duration_ms")
  success       Boolean      @default(true)
  errorMessage  String?      @map("error_message")
  invokedAt     DateTime     @default(now()) @map("invoked_at") @db.Timestamptz
  metadata      Json?        @db.JsonB

  @@index([sessionId])
  @@index([toolName])
  @@index([invokedAt])
  @@map("agent_invocations")
}

/// Append-only audit log for all agent-related security events.
model AgentAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  agentSlug   String?  @map("agent_slug")
  instanceId  String?  @map("instance_id")
  action      String
  status      String   @default("success")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  reason      String?
  metadata    Json?    @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([actorUserId])
  @@index([agentSlug])
  @@index([action])
  @@index([createdAt])
  @@map("agent_audit_logs")
}

// ============================================================================
// Legacy: Generic Key-Value Storage (retained for backward compatibility)
// ============================================================================

model StorageEntry {
  id        String    @id @default(cuid())
  key       String    @unique
  data      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  expiresAt DateTime? @map("expires_at")
  tags      String?

  @@index([key])
  @@index([expiresAt])
  @@map("storage_entries")
}

model FilterCache {
  id        String    @id @default(cuid())
  source    String    @unique
  content   String
  hash      String
  etag      String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  expiresAt DateTime? @map("expires_at")

  @@index([source])
  @@index([expiresAt])
  @@map("filter_cache")
}

// ============================================================================
// Legacy: Compilation Metadata (retained for backward compatibility with PrismaStorageAdapter)
// ============================================================================
// TODO(Phase 2): Migrate callers to use CompiledOutput + CompilationEvent instead.

model CompilationMetadata {
  id          String   @id @default(cuid())
  configName  String
  timestamp   DateTime @default(now())
  sourceCount Int
  ruleCount   Int
  duration    Int      // Duration in milliseconds
  outputPath  String?

  @@index([configName])
  @@index([timestamp])
  @@map("compilation_metadata")
}

// ============================================================================
// Data Retention Consent — append-only compliance/transparency log
// ============================================================================

/// Append-only record of user/org consent to the data retention policy.
/// A new row is inserted each time the policy version changes and the user/org accepts.
/// NEVER delete rows from this table — it is an audit trail.
/// Users and orgs should be informed of:
///   - what categories of data are stored
///   - why each category is stored
///   - how long each category is retained (retentionDays)
model DataRetentionConsent {
  id              String   @id @default(uuid()) @db.Uuid

  // One of these is set — user-level or org-level consent
  userId          String?  @map("user_id") @db.Uuid
  organizationId  String?  @map("organization_id") @db.Uuid

  policyVersion   String   @map("policy_version")   // e.g. "2026-04" — bump when policy changes
  retentionDays   Int      @map("retention_days")   // the retention window accepted
  // Categories of data the user/org was informed about when consenting.
  // Examples: "compilation_events", "agent_sessions", "filter_sources", "filter_list_asts"
  dataCategories  String[] @map("data_categories")

  acceptedAt      DateTime @default(now()) @map("accepted_at") @db.Timestamptz
  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent")

  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@index([acceptedAt(sort: Desc)])
  @@map("data_retention_consents")
}

// ============================================================================
// User Configurations — saved configurations for authenticated users (legacy)
// ============================================================================

model UserConfiguration {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  description String?
  config      Json     @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("user_configurations")
}

// ============================================================================
// Deployment History — tracks worker deployments (migrated from D1)
// ============================================================================

model DeploymentHistory {
  id                 String    @id
  version            String
  buildNumber        Int       @map("build_number")
  fullVersion        String    @unique @map("full_version")
  gitCommit          String    @map("git_commit")
  gitBranch          String    @map("git_branch")
  deployedAt         DateTime  @default(now()) @map("deployed_at") @db.Timestamptz
  deployedBy         String    @map("deployed_by")
  status             String    @default("success")
  deploymentDuration Int?      @map("deployment_duration")
  workflowRunId      String?   @map("workflow_run_id")
  workflowRunUrl     String?   @map("workflow_run_url")
  metadata           Json?     @db.JsonB

  @@unique([version, buildNumber], name: "deployment_history_unique_deployment")
  @@index([version])
  @@index([buildNumber])
  @@index([deployedAt(sort: Desc)])
  @@index([status])
  @@index([gitCommit])
  @@map("deployment_history")
}

model DeploymentCounter {
  version         String   @id
  lastBuildNumber Int      @default(0) @map("last_build_number")
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("deployment_counter")
}
