{
    "name": "adblock-compiler",
    "version": "0.92.0",
    "description": "Compiler-as-a-Service for adblock filter lists",
    "homepage": "https://bloqr-backend.jk-com.workers.dev/",
    "type": "module",
    "scripts": {
        "ui:build": "pnpm --filter bloqr-frontend run build",
        "ui:dev": "pnpm --filter bloqr-frontend run start",
        "ui:test": "pnpm --filter bloqr-frontend run test",
        "ui:lint": "pnpm --filter bloqr-frontend run lint",
        "build:worker": "pnpm install && pnpm --filter bloqr-frontend run build",
        "tail": "wrangler tail bloqr-backend --format=pretty",
        "tail:worker": "wrangler tail bloqr-backend --format=pretty",
        "tail:tail": "wrangler tail bloqr-tail --format=pretty",
        "test:worker:vitest": "vitest --config vitest.worker.config.ts",
        "docs:docusaurus:build": "pnpm --filter @bloqr/docs-docusaurus run build",
        "docs:starlight:build": "pnpm --filter @bloqr/docs-starlight run build"
    },
    "packageManager": "pnpm@10.31.0",
    "_syncNote": "Dependency versions here must match those pinned in deno.json's import map; keep them in sync (for example via the existing version:sync-style task).",
    "dependencies": {
        "@adguard/agtree": "^4.0.4",
        "@better-auth/infra": "^0.2.5",
        "@hono/zod-openapi": "^1.2.2",
        "@hono/zod-validator": "^0.4.3",
        "@neondatabase/serverless": "^0.10.0",
        "@opentelemetry/api": "^1.9.1",
        "@prisma/adapter-d1": "^7.5.0",
        "@prisma/adapter-pg": "^7.5.0",
        "@prisma/client": "^7.5.0",
        "@sentry/cloudflare": "10.43.0",
        "@trpc/client": "^11.15.1",
        "@trpc/server": "^11.15.1",
        "better-auth": "^1.5.6",
        "cloudflare": "^5.2.0",
        "hono": "^4.12.12",
        "jose": "^6.2.1",
        "pg": "^8.20.0",
        "svix": "^1.89.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@cloudflare/containers": "^0.1.1",
        "@cloudflare/playwright": "^1.2.0",
        "@cloudflare/playwright-mcp": "^0.0.5",
        "@cloudflare/vitest-pool-workers": "^0.14.2",
        "@cloudflare/workers-types": "^4.20260426.1",
        "@sentry/cli": "^3.4.1",
        "agents": "^0.8.0",
        "prisma": "7.8.0",
        "vitest": "^4.1.0",
        "wrangler": "^4.86.0"
    },
    "pnpm": {
        "overrides": {
            "@opentelemetry/api": "^1.9.1",
            "vite": "7.3.2",
            "undici@>=7.0.0 <7.24.0": "7.24.4",
            "picomatch@<2.3.2": "2.3.2",
            "picomatch@>=4.0.0 <4.0.4": "4.0.4",
            "path-to-regexp@<0.1.13": "0.1.13",
            "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
            "hono": "4.12.12",
            "@hono/node-server": "1.19.13",
            "lodash": "4.18.1",
            "serialize-javascript": "7.0.5",
            "defu": "6.1.5",
            "effect": "3.20.0",
            "jose@<6.2.2": "6.2.2"
        },
        "onlyBuiltDependencies": [
            "@parcel/watcher",
            "@prisma/engines",
            "@sentry/cli",
            "lmdb",
            "msgpackr-extract",
            "prisma",
            "workerd"
        ]
    }
}
