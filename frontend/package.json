{
    "name": "adblock-frontend",
    "version": "1.1.0",
    "description": "Angular 21 frontend for Adblock Compiler with Material Design, Zoneless Change Detection, and Cloudflare Workers SSR",
    "private": true,
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "build:dev": "ng build --configuration development",
        "postbuild": "node scripts/postbuild.js",
        "watch": "ng build --watch --configuration development",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "ng lint",
        "test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
        "test:e2e:headed": "npx playwright test --config=e2e/playwright.config.ts --headed",
        "test:e2e:ui": "npx playwright test --config=e2e/playwright.config.ts --ui",
        "test:e2e:debug": "npx playwright test --config=e2e/playwright.config.ts --debug",
        "test:e2e:report": "npx playwright show-report",
        "test:e2e:codegen": "npx playwright codegen http://localhost:4200",
        "preview": "wrangler dev",
        "deploy": "wrangler deploy",
        "deploy:dev": "wrangler deploy --env dev"
    },
    "dependencies": {
        "@analogjs/vite-plugin-angular": "^2.3.1",
        "@angular/animations": "^21.2.7",
        "@angular/cdk": "^21.2.2",
        "@angular/common": "^21.2.7",
        "@angular/compiler": "^21.2.7",
        "@angular/core": "^21.2.7",
        "@angular/forms": "^21.2.7",
        "@angular/material": "^21.2.3",
        "@angular/platform-browser": "^21.2.7",
        "@angular/platform-browser-dynamic": "^21.2.7",
        "@angular/platform-server": "^21.2.7",
        "@angular/router": "^21.2.7",
        "@angular/service-worker": "^21.2.7",
        "@angular/ssr": "^21.2.5",
        "@fontsource/ibm-plex-sans": "^5.2.8",
        "@fontsource/jetbrains-mono": "^5.2.8",
        "@fontsource/syne": "^5.2.7",
        "@sentry/angular": "^10.43.0",
        "@sentry/cloudflare": "^10.43.0",
        "@trpc/client": "^11.15.1",
        "hono": "^4.12.12",
        "material-symbols": "^0.40.2",
        "rxjs": "~7.8.2",
        "tslib": "^2.8.1",
        "yaml": "^2.8.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@analogjs/vitest-angular": "^2.3.1",
        "@angular-devkit/build-angular": "^21.2.2",
        "@angular-eslint/builder": "^21.3.0",
        "@angular/cli": "^21.2.2",
        "@angular/compiler-cli": "^21.2.7",
        "@cloudflare/workers-types": "^4.20260317.1",
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.58.2",
        "@sentry/cli": "^3.3.3",
        "@tailwindcss/postcss": "^4.2.1",
        "@vitest/coverage-v8": "^4.1.0",
        "angular-eslint": "^21.3.0",
        "eslint": "^10.0.3",
        "jsdom": "^28.1.0",
        "postcss": "^8.5.8",
        "tailwindcss": "^4.2.1",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.57.2",
        "vitest": "^4.1.0"
    }
}
