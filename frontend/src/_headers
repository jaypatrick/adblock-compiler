# Cloudflare Workers Static Assets — custom response headers.
# See: https://developers.cloudflare.com/workers/static-assets/headers/
#
# Strategy:
#   Content-hashed assets (JS/CSS chunks, fonts, images in /media/) are safe to
#   cache forever because their filenames change whenever the content changes.
#   Use `immutable` to skip conditional revalidation on repeat visits.
#
#   index.html and other unhashed entry points (e.g. /assets/endpoint-registry.json)
#   must always revalidate so users pick up new deployments immediately.
#   /assets/* is intentionally omitted — it contains runtime JSON that is NOT
#   content-hashed and must not be cached immutably.

/media/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable
