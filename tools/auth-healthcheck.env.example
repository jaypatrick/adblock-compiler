# ============================================================================
# auth-healthcheck.env — local config for auth-healthcheck.py
# ============================================================================
# Copy this file to auth-healthcheck.env and fill in your values.
# auth-healthcheck.env is gitignored — never commit real credentials.
#
# The script loads this file automatically — no `export` needed.
# ============================================================================

# ── Target API ──────────────────────────────────────────────────────────────
# Production API base URL (include /api suffix)
API_BASE=https://api.bloqr.dev/api

# ── Test user ───────────────────────────────────────────────────────────────
# Leave TEST_EMAIL blank to generate a unique email each run (recommended).
# Set a fixed email to reuse across runs (user will already exist on run 2+).
TEST_EMAIL=
TEST_PASSWORD=HealthCheck1234!!@@
TEST_NAME=Auth Healthcheck Bot

# ── Neon / PostgreSQL ────────────────────────────────────────────────────────
# Direct connection string from Neon Console → Branch → "Direct connection"
# Format: postgresql://user:pass@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
NEON_URL=postgresql://<user>:<pass>@<host>.neon.tech/<db>?sslmode=require

# ── Better Auth admin API key (optional) ────────────────────────────────────
# Enables /api/admin/list-users check. Get from dash.better-auth.com or
# set BETTER_AUTH_API_KEY in your wrangler secrets.
BETTER_AUTH_API_KEY=

# ── Wrangler bindings ────────────────────────────────────────────────────────
KV_BINDING=BETTER_AUTH_KV
D1_BINDING=DB
D1_ADMIN_BINDING=ADMIN_DB

# ── Wrangler environment ─────────────────────────────────────────────────────
# Leave blank for production default. Use "dev" for local wrangler dev.
WRANGLER_ENV=

# ── Tail logs ────────────────────────────────────────────────────────────────
ENABLE_TAIL=true
TAIL_WAIT_SEC=4
