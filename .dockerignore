# Version Control
.git
.gitignore
.gitattributes
.github/

# Secrets & Environment (never copy to image; pass via -e or --env-file)
.env
.env.*
!.env.example
.env.local
.env.*.local
.envrc

# Package Manager
node_modules/
npm-debug.log*
yarn-error.log*
pnpm-error.log*
.npmrc
frontend/.npmrc

# Deno
.deno/
deno.lock.bak

# Build & Dist Artifacts (rebuilt in Docker)
dist/
build/
*.tsbuildinfo
.tsconfig.tsbuildinfo

# Frontend Framework Cache
frontend/.angular/
frontend/dist/
frontend/node_modules/
frontend/.wrangler/
frontend/.next/
frontend/out/
frontend/.vuepress/dist/

# Testing
test-results/
playwright-report/
coverage/
cov_profile/
coverage.lcov
*.lcov
.nyc_output/

# Database & Persistent Data (Docker should use volumes)
*.db
*.db-journal
*.db-wal
*.db-shm
data/
*.sqlite
*.sqlite3

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*.iml
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Wrangler & Cloudflare
.wrangler/
worker-configuration.d.ts
.deployment-version.json
.dev.vars

# Logs
*.log
*.log.*
logs/

# Temporary Files
tmp/
temp/
*.tmp
*.bak
*.orig

# Documentation (keep README for reference)
*.md
!README.md

# Examples & POC
examples/
# Allow only the workspace member config needed by `deno cache` in Dockerfile.container
!examples/cloudflare-worker/deno.json
poc/
ideas/
issues/
pull_requests/

# Output & Artifacts (not needed in image)
output/
artifacts/
dist/
build/

# CI/CD & Deployment
.github/
.gitlab-ci.yml
.circleci/
jenkins/
.travis.yml

# Cloudflare-specific
Dockerfile.container
wrangler.*.toml
!wrangler.toml

# Memory & Debugging
.remember/
.claude/

# Misc
.pre-commit-config.yaml
.trivyignore
book.toml
pnpm-workspace.yaml.bak
