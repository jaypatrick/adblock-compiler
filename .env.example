# ============================================================================
# .env.example — Shell-tooling environment reference
# ============================================================================
# Copy this file to .env.local and fill in your actual values.
# Run `direnv allow` once after cloning to activate automatic loading.
#
# SCOPE: This file (and .env, .env.development, .env.production) covers ONLY
#        shell-level tooling — Prisma CLI, Deno tasks, and local scripts.
#        These files are NOT read by the Wrangler Worker runtime.
#
#        Worker secrets and runtime vars → see .dev.vars.example instead.
#
# Environment Loading Order (via .envrc):
#   1. .env              — Base non-secret defaults         (committed)
#   2. .env.$ENV         — Branch-specific defaults         (committed)
#   3. .env.local        — Your local shell overrides       (gitignored)
#   4. .dev.vars         — Wrangler Worker secrets          (gitignored, loaded last)
#
# $ENV is determined by your git branch:
#   main         → production  → .env.production
#   dev/develop  → development → .env.development
#   other        → local       → .env.local only
# ============================================================================

# ─── Core / Server ───────────────────────────────────────────────────────────
# Server port used by local scripts. The Worker itself binds to its own port.
# PORT=8787

# ─── Database (Prisma CLI, migrations, introspection) ────────────────────────
# Primary connection URL used by Prisma CLI for migrations, db push, studio.
# For local Docker dev:   postgresql://adblock:localdev@localhost:5432/adblock_dev
# For Neon direct:        postgresql://user:pass@ep-xxx.region.azure.neon.tech/adblock-compiler?sslmode=require
DATABASE_URL="postgresql://adblock:localdev@localhost:5432/adblock_dev"

# Direct (non-pooled) URL — preferred by prisma.config.ts for schema operations.
# Same as DATABASE_URL for Docker; use the non-pooled Neon endpoint for production.
DIRECT_DATABASE_URL="postgresql://adblock:localdev@localhost:5432/adblock_dev"

# Prisma Accelerate proxy (optional — only needed for cloud Prisma Accelerate)
# PRISMA_DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=your_api_key_here"

# ─── Neon Platform (scripts + CI/CD) ─────────────────────────────────────────
# Used by migration scripts, CI/CD workflows, and admin tooling.
# Get API key from https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=neon-api-key-here
# Neon project ID — find in Console → Project Settings → General
NEON_PROJECT_ID=your-neon-project-id
# Direct Neon connection string (non-pooled, for migrations against prod)
# NEON_DATABASE_URL="postgresql://user:pass@ep-xxx.region.azure.neon.tech/adblock-compiler?sslmode=require"

# ─── Cloudflare API (scripts + CI/CD) ────────────────────────────────────────
# Used by scripts that call the Cloudflare API directly (not the Worker runtime).
# Get from https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
# Warp/1.1.1.1 API key (optional)
# WARP_API_KEY=your_warp_api_key

# ─── Cloudflare Web Analytics ─────────────────────────────────────────────────
# Get from https://dash.cloudflare.com/?to=/:account/web-analytics
# Injected into index.html at build time by scripts/build-worker.sh.
CF_WEB_ANALYTICS_TOKEN=your_web_analytics_token_here

# ─── Cloudflare Access (CI/CD service tokens) ────────────────────────────────
# Used by scripts/CI that call admin endpoints protected by CF Access.
# Get from Zero Trust Dashboard → Access → Service Tokens
CF_ACCESS_TEAM_DOMAIN=your-team-name
CF_ACCESS_AUD=your-audience-tag-here
# CF_ACCESS_CLIENT_ID=your-service-token-client-id
# CF_ACCESS_CLIENT_SECRET=your-service-token-client-secret

# ─── Sentry (error reporting — CI/CD + source maps) ──────────────────────────
# Used by CI/CD to upload source maps and release info.
# Get from https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug
# Worker runtime DSN — also needed in .dev.vars for local dev
# SENTRY_DSN=https://...@sentry.io/...

# ─── GitHub (CI/CD + scripts) ────────────────────────────────────────────────
# Personal access token for GitHub API calls from local scripts.
# Not needed in CI/CD — GitHub Actions provides GITHUB_TOKEN automatically.
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# ─── CI/CD Integrations ──────────────────────────────────────────────────────
# CODECOV_TOKEN=your_codecov_upload_token
# POSTMAN_API_KEY=your_postman_api_key

# ─── Logging (shell / Deno process logging) ──────────────────────────────────
# Controls the Deno-layer logger; does NOT affect the Worker's internal logger.
# LOG_LEVEL=debug        # debug | info | warn | error
# LOG_STRUCTURED=false   # true = JSON output; false = human-readable

# ─── Testing & Local Development ─────────────────────────────────────────────
# Base URL for E2E and contract tests
# E2E_BASE_URL=http://localhost:8787
# Set to "true" to skip OpenAPI contract tests (e.g. in offline CI)
# SKIP_CONTRACT_TESTS=false
# Storage backend selection: memory | prisma (default: prisma in production, memory in tests)
# STORAGE_BACKEND=memory
# D1 database ID (used by scripts that reference D1 directly, not the worker runtime binding)
# D1_DATABASE_ID=your-d1-database-id-here

# ─── Optional Integrations ───────────────────────────────────────────────────
# OPTIMIZE_API_KEY=your_optimize_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-id/your-token
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook

# ─── Angular Frontend ────────────────────────────────────────────────────────
# The frontend runs on port 4200 by default (ng serve).
# The backend Wrangler dev server runs on port 8787.
# In local dev, the frontend proxies /api requests to the backend.
#
# To build the frontend:  pnpm --filter adblock-frontend build
# To serve locally:       pnpm --filter adblock-frontend start
# To run frontend tests:  pnpm --filter adblock-frontend test
# To lint frontend:       pnpm --filter adblock-frontend lint
# To run E2E tests:       pnpm --filter adblock-frontend test:e2e

# ─────────────────────────────────────────────────────────────────────────────
# Worker runtime vars (BETTER_AUTH_SECRET, CLERK_*, TURNSTILE_*, SENTRY_DSN,
# ANALYTICS_*, CORS_*, HYPERDRIVE, MAX_REQUEST_BODY_MB, ERROR_REPORTER_*,
# OTEL_EXPORTER_OTLP_ENDPOINT, WEBHOOK_URL, etc.) belong in .dev.vars (local)
# or `wrangler secret put` (production) — NOT in .env* files.
# See .dev.vars.example for the complete annotated Worker runtime template.
# ─────────────────────────────────────────────────────────────────────────────
