# ============================================================================
# .dev.vars.example — Wrangler Worker runtime template
# ============================================================================
# Copy this file to .dev.vars and fill in your values.
# .dev.vars is loaded automatically by both `wrangler dev` and direnv.
# Do NOT commit .dev.vars — it contains real credentials.
#
# SCOPE: Everything the Worker reads at runtime — non-secrets (publishable
#        keys, public URLs) AND secrets. This is the single source of truth
#        for what the Worker sees during `wrangler dev`.
#
# Production equivalents:
#   Non-secrets  → wrangler.toml [vars]          (committed, this repo)
#   Secrets      → `wrangler secret put <KEY>`   (Cloudflare dashboard)
#
# See docs/auth/configuration.md for per-variable guidance.
# ============================================================================

# ─── Environment flag ────────────────────────────────────────────────────────
# Overrides ENVIRONMENT="production" from wrangler.toml [vars] during local dev.
ENVIRONMENT=development

# ─── Better Auth (primary) ───────────────────────────────────────────────────
# Better Auth is the primary authentication provider for new sessions.
# Must be 32+ characters. Generate: openssl rand -base64 32
# Production: `wrangler secret put BETTER_AUTH_SECRET`
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32-output
# Base URL for Better Auth callbacks and redirects
BETTER_AUTH_URL=http://localhost:8787
# Better Auth Dash API key — only required for dash.better-auth.com dashboard integration
# Production: `wrangler secret put BETTER_AUTH_API_KEY`
BETTER_AUTH_API_KEY=

# ─── Cloudflare Turnstile ────────────────────────────────────────────────────
# Site key (non-secret — production value lives in wrangler.toml [vars])
# Test keys below always pass verification — safe for local dev.
# Get real keys from https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Secret key (secret — production: `wrangler secret put TURNSTILE_SECRET_KEY`)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated origin allowlist (secret — production: `wrangler secret put CORS_ALLOWED_ORIGINS`)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8787

# ─── Hyperdrive (local connection override) ───────────────────────────────────
# wrangler dev does NOT use the HYPERDRIVE binding — it uses this env var as a
# passthrough to the Postgres URL you provide. Point this at your personal Neon
# development branch (create one at https://console.neon.tech → your project →
# Branches → New Branch). Use the "Direct connection" string (not pooled).
# See: https://neon.com/guides/local-development-with-neon
# See: https://developers.cloudflare.com/hyperdrive/configuration/local-development/
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgresql://<user>:<password>@<branch-host>.neon.tech/<dbname>?sslmode=require

# ─── Neon Admin API (optional — for /admin/neon/* endpoints) ──────────────────
# Needed for admin reporting endpoints that call the Neon platform REST API.
# Get API key from https://console.neon.tech/app/settings/api-keys
# Get project ID from Neon Console → Project Settings → General
NEON_API_KEY=neon-api-key-here
NEON_PROJECT_ID=your-neon-project-id

# ─── Cloudflare Access (optional — admin route defense-in-depth) ─────────────
# Get from Zero Trust Dashboard → Access → Applications
# CF_ACCESS_TEAM_DOMAIN=your-team-name
# CF_ACCESS_AUD=your-audience-tag-here

# ─── Request Limits (optional) ───────────────────────────────────────────────
# Max request body in MB; Worker defaults to 1 if unset.
# MAX_REQUEST_BODY_MB=10

# ─── Observability (all optional) ────────────────────────────────────────────
# Sentry DSN (secret — production: `wrangler secret put SENTRY_DSN`)
# SENTRY_DSN=https://...@sentry.io/...
# Git SHA / release tag for Sentry source map association
# SENTRY_RELEASE=
# Cloudflare Analytics Engine SQL API credentials
# (secrets — production: `wrangler secret put ANALYTICS_ACCOUNT_ID`)
# ANALYTICS_ACCOUNT_ID=your-cf-account-id
# ANALYTICS_API_TOKEN=your-cf-api-token
# OpenTelemetry OTLP collector endpoint — DISABLED (Grafana Phase 2)
# The OTel provider is commented out in worker/services/diagnostics-factory.ts.
# TODO(grafana-phase2): Un-comment the import and provider registration in
#   worker/services/diagnostics-factory.ts, then set this secret.
# (secret — production: `wrangler secret put OTEL_EXPORTER_OTLP_ENDPOINT`)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.grafana.net/otlp
# Error reporter type: console | cloudflare | sentry | composite
# ERROR_REPORTER_TYPE=composite
# Set 'true' to enable verbose console output from the error reporter
# ERROR_REPORTER_VERBOSE=false

# ─── Optional integrations ───────────────────────────────────────────────────
# Generic webhook target for POST /api/notify
# WEBHOOK_URL=https://your-webhook-endpoint.example.com/hook
# Datadog API key for POST /api/notify
# DATADOG_API_KEY=your-datadog-api-key

# ─── Cloudflare Containers ────────────────────────────────────────────────────
# Required for local container dev (POST /compile/container).
# Must match the value set in the container environment.
# For production: wrangler secret put CONTAINER_SECRET
CONTAINER_SECRET=dev-local-secret

# ─── Project URLs (non-secret — production values live in wrangler.toml [vars]) ─
# Override these for local dev; they default to the *.workers.dev production URLs.
URL_FRONTEND=http://localhost:4200
URL_API=http://localhost:8787
URL_DOCS=https://docs.bloqr.jaysonknight.com

# ─── Stripe (PAYG + Subscriptions) ───────────────────────────────────────────
# Publishable key (non-secret — safe to expose to frontend, wrangler.toml [vars])
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# Secret key (secret — production: `wrangler secret put STRIPE_SECRET_KEY`)
# STRIPE_SECRET_KEY=sk_test_...
# Stripe webhook signing secret (secret — production: `wrangler secret put STRIPE_WEBHOOK_SECRET`)
# STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe PAYG price ID (non-secret — wrangler.toml [vars])
# STRIPE_PAYG_PRICE_ID=price_...
# PAYG price per API call in USD cents (default: 1 = $0.01)
# PAYG_PRICE_PER_CALL_USD_CENTS=1
# PAYG spend threshold in USD cents for subscription upsell (default: 2000 = $20)
# PAYG_CONVERSION_THRESHOLD_USD_CENTS=2000

# ─── Cloudflare Page Shield (Worker runtime secrets) ──────────────────────────
# Zone ID for Page Shield API access. Required for the hourly Page Shield sync cron.
# wrangler secret put CF_ZONE_ID
# CF_ZONE_ID=your_zone_id_here
# Scoped CF API token with Zone.Page Shield read permissions.
# wrangler secret put CF_PAGE_SHIELD_API_TOKEN
# CF_PAGE_SHIELD_API_TOKEN=your_page_shield_api_token_here

# ─── Email (Resend — critical auth path: verification, reset, security alerts) ─
# Get a test API key from https://resend.com/api-keys
# Production: `wrangler secret put RESEND_API_KEY`
RESEND_API_KEY=re_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Email (Cloudflare Email Service REST — transactional notifications) ────────
# Scoped CF API token with Email Send permissions.
# Production: `wrangler secret put CF_EMAIL_API_TOKEN`
CF_EMAIL_API_TOKEN=your_cf_email_api_token_here
# Your Cloudflare account ID (non-secret — find in Cloudflare dashboard)
CF_ACCOUNT_ID=your_cloudflare_account_id_here
