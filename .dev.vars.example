# ============================================================================
# .dev.vars.example — Wrangler Worker runtime template
# ============================================================================
# Copy this file to .dev.vars and fill in your values.
# .dev.vars is loaded automatically by both `wrangler dev` and direnv.
# Do NOT commit .dev.vars — it contains real credentials.
#
# SCOPE: Everything the Worker reads at runtime — non-secrets (publishable
#        keys, public URLs) AND secrets. This is the single source of truth
#        for what the Worker sees during `wrangler dev`.
#
# Production equivalents:
#   Non-secrets  → wrangler.toml [vars]          (committed, this repo)
#   Secrets      → `wrangler secret put <KEY>`   (Cloudflare dashboard)
#
# See docs/auth/configuration.md for per-variable guidance.
# ============================================================================

# ─── Environment flag ────────────────────────────────────────────────────────
# Overrides ENVIRONMENT="production" from wrangler.toml [vars] during local dev.
ENVIRONMENT=development

# ─── Clerk Authentication ────────────────────────────────────────────────────
# Get keys from https://dashboard.clerk.com → API Keys
# Publishable key (non-secret — production value lives in wrangler.toml [vars])
CLERK_PUBLISHABLE_KEY=pk_test_...
# JWKS URL (non-secret — production value lives in wrangler.toml [vars])
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# Secret key (secret — production: `wrangler secret put CLERK_SECRET_KEY`)
CLERK_SECRET_KEY=sk_test_...
# Webhook signing secret (secret — production: `wrangler secret put CLERK_WEBHOOK_SECRET`)
CLERK_WEBHOOK_SECRET=whsec_...

# ─── Local JWT Auth (pre-Clerk bridge) ───────────────────────────────────────
# HS256 signing secret for LocalJwtAuthProvider (active when CLERK_JWKS_URL is unset).
# Generate: openssl rand -base64 32
# Production: `wrangler secret put JWT_SECRET`
# MIGRATION: once CLERK_JWKS_URL is set above, this key is no longer used.
JWT_SECRET=replace-with-openssl-rand-base64-32-output

# ─── Bootstrap Admin ─────────────────────────────────────────────────────────
# Email of the first admin user. When set, POST /auth/bootstrap-admin promotes
# the signed-in user matching this email to the 'admin' role.
# Remove once the first admin is set.
# INITIAL_ADMIN_EMAIL=you@example.com

# ─── Cloudflare Turnstile ────────────────────────────────────────────────────
# Site key (non-secret — production value lives in wrangler.toml [vars])
# Test keys below always pass verification — safe for local dev.
# Get real keys from https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Secret key (secret — production: `wrangler secret put TURNSTILE_SECRET_KEY`)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated origin allowlist (secret — production: `wrangler secret put CORS_ALLOWED_ORIGINS`)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8787

# ─── Hyperdrive (local PostgreSQL override) ───────────────────────────────────
# Overrides the Hyperdrive binding for `wrangler dev` with a direct connection.
# See: https://developers.cloudflare.com/hyperdrive/configuration/local-development/
WRANGLER_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgresql://user:password@127.0.0.1:5432/adblock_dev?sslmode=verify-full&sslrootcert=system

# ─── Cloudflare Access (optional — admin route defense-in-depth) ─────────────
# Get from Zero Trust Dashboard → Access → Applications
# CF_ACCESS_TEAM_DOMAIN=your-team-name
# CF_ACCESS_AUD=your-audience-tag-here

# ─── Request Limits (optional) ───────────────────────────────────────────────
# Max request body in MB; Worker defaults to 1 if unset.
# MAX_REQUEST_BODY_MB=10

# ─── Observability (all optional) ────────────────────────────────────────────
# Sentry DSN (secret — production: `wrangler secret put SENTRY_DSN`)
# SENTRY_DSN=https://...@sentry.io/...
# Git SHA / release tag for Sentry source map association
# SENTRY_RELEASE=
# Cloudflare Analytics Engine SQL API credentials
# (secrets — production: `wrangler secret put ANALYTICS_ACCOUNT_ID`)
# ANALYTICS_ACCOUNT_ID=your-cf-account-id
# ANALYTICS_API_TOKEN=your-cf-api-token
# OpenTelemetry OTLP collector endpoint — DISABLED (Grafana Phase 2)
# The OTel provider is commented out in worker/services/diagnostics-factory.ts.
# TODO(grafana-phase2): Un-comment provider registration and set this secret.
# (secret — production: `wrangler secret put OTEL_EXPORTER_OTLP_ENDPOINT`)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.grafana.net/otlp
# Error reporter type: console | cloudflare | sentry | composite
# ERROR_REPORTER_TYPE=composite
# Set 'true' to enable verbose console output from the error reporter
# ERROR_REPORTER_VERBOSE=false

# ─── Optional integrations ───────────────────────────────────────────────────
# Generic webhook target for POST /api/notify
# WEBHOOK_URL=https://your-webhook-endpoint.example.com/hook
# Datadog API key for POST /api/notify
# DATADOG_API_KEY=your-datadog-api-key